# =============================================================================
# Enterprise RAT - Environment Variables Template
# Copy this to .env and fill in the values for your deployment
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_password_here
POSTGRES_DB=ratdb

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# ENV=development | production
ENV=production

# Server port (default: 8080)
PORT=8080

# Domain for CORS and SSL (e.g., your-domain.com or IP)
DOMAIN=your-domain-or-ip

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
JWT_SECRET=changeme_generate_a_secure_random_string

# Generate with: openssl rand -base64 32
AGENT_ENROLLMENT_SECRET=changeme_another_secure_random_string

# Comma-separated list of allowed origins
# Example: https://your-domain.com,https://admin.your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com

# -----------------------------------------------------------------------------
# Let's Encrypt (SSL Certificate)
# -----------------------------------------------------------------------------
LETSENCRYPT_EMAIL=admin@your-domain.com

# -----------------------------------------------------------------------------
# Nginx Ports
# -----------------------------------------------------------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# -----------------------------------------------------------------------------
# Agent Configuration (for agent binary)
# -----------------------------------------------------------------------------
# RAT_SERVER_URL=wss://your-domain.com/api/v1/ws
# RAT_AGENT_TOKEN=optional_token_if_needed
# AGENT_ENROLLMENT_SECRET=same_as_backend

# =============================================================================
# NOTES:
# 1. Never commit .env files to version control
# 2. Use different secrets for production vs development
# 3. Ensure DOMAIN resolves to your server IP
# 4. Run migrations before starting the server
# =============================================================================