# Backend Environment Configuration Example
# Copy this file to .env and update values for your environment

# Database Configuration
DB_URL=postgres://postgres:password@localhost:5432/ratdb?sslmode=disable

# Server Configuration
PORT=8080

# JWT Configuration
# IMPORTANT: Generate a secure secret using: openssl rand -base64 32
# Do NOT use default or example values in production
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_SECRET_32_CHARS

# For production, consider adding:
# CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
# DATABASE_URL=postgresql://user:password@host:5432/ratdb?sslmode=require
# LOG_LEVEL=info
